{
  "name": "@ironqr/bench",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "bench": "bun src/cli.ts",
    "build": "tsup --config tsup.config.ts",
    "clean": "rm -rf dist",
    "lint": "biome check .",
    "migrate:study-cache": "bun scripts/migrate-study-cache.ts",
    "test": "bun test tests/unit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@opentui/core": "0.1.103",
    "@techstark/opencv-js": "^4.12.0-release.1",
    "@undecaf/zbar-wasm": "^0.11.0",
    "@zxing/library": "^0.21.3",
    "jsqr": "^1.4.0",
    "quirc": "^1.0.0-alpha.4",
    "sharp": "^0.34.4",
    "zxing-wasm": "^3.0.2"
  }
}
