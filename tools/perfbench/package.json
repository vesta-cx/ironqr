{
  "name": "@ironqr/perfbench",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "clean": "rm -rf dist",
    "lint": "biome check .",
    "test": "bun test tests/unit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "benchmark": "bun src/cli.ts"
  },
  "dependencies": {
    "ironqr-corpus-cli": "workspace:*",
    "ironqr": "workspace:*"
  }
}
