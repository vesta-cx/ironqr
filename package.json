{
  "type": "module",
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "^2.4.10",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^24.6.1",
    "bun-types": "1.3.11",
    "publint": "^0.3.18",
    "tsup": "^8.5.1",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.3.11",
    "node": ">=24"
  },
  "name": "@ironqr/workspace",
  "packageManager": "bun@1.3.11",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean --continue && rm -rf node_modules",
    "dev": "turbo run dev --parallel",
    "format": "biome check --write .",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "package:quality": "turbo run package:quality --filter=ironqr",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "benchmark": "turbo run benchmark --filter=@ironqr/perfbench",
    "corpus:import": "turbo run corpus:import --filter=ironqr-corpus-cli",
    "corpus:scrape": "turbo run corpus:scrape --filter=ironqr-corpus-cli",
    "corpus:review": "turbo run corpus:review --filter=ironqr-corpus-cli",
    "corpus:import-staged": "turbo run corpus:import-staged --filter=ironqr-corpus-cli",
    "corpus:export": "turbo run corpus:export --filter=ironqr-corpus-cli"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ]
}
